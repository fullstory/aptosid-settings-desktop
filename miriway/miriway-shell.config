# LXQt shell for the Miriway (Mir/Wayland) compositor. startlxqtwayland has
# no miriway branch, so it runs `exec miriway`, which reads this file from
# ~/.config (seeded from /etc/skel by fll_desktop; fll_desktop appends the
# live keymap). Miriway grants layer-shell only to shell-components, so the
# panel, wallpaper and launcher are started as such, not via lxqt-session.
#
# Config path: miriway-shell locates "miriway-shell.config" via the XDG base
# dirs, so ~/.config is correct for lxqt-wayland-session <= 0.3.1 (no miriway
# branch). When upstream PR#40 (lxqt/lxqt-wayland-session) lands, startlxqtwayland
# gains a miriway branch + wrapper and expects the config under
# ~/.config/lxqt/wayland/ (still named miriway-shell.config): move it there and
# drop the ~/.config seeding in fll_desktop then, not before.
x11-window-title=LXQt (Miriway)
idle-timeout=600

# MIR_ANCHOR_RECTANGLE_UNCONSTRAINED works around Mir mis-placing menu/popup
# surfaces whose anchor rect sits outside the parent (submenus on non-top
# panels). Taken from Miriway's own LXQt example config.
env-hacks=MIR_ANCHOR_RECTANGLE_UNCONSTRAINED=1

# Do NOT amend XDG_CURRENT_DESKTOP here: startlxqtwayland exports it as
# "LXQt:miriway:wlroots", and apps inherit that. Keeping it intact matters for
# lxqt-panel, which scores its taskbar backend by token - stock lxqt-panel
# scores "miriway" 0 (dummy backend, no task list) but "wlroots" highest, so
# the inherited "wlroots" gives a working taskbar without patching lxqt-panel.
# (miriway's own default sets XDG_CURRENT_DESKTOP=Miriway for standalone use;
# overriding it here would break the panel.)
app-env-amend=XDG_SESSION_TYPE=wayland:GTK_USE_PORTAL=0:GTK_A11Y=none

shell-component=dbus-update-activation-environment --systemd DISPLAY WAYLAND_DISPLAY XDG_SESSION_TYPE XDG_CURRENT_DESKTOP
# pcmanfm-qt paints the desktop (wallpaper + icons) as a layer-shell surface,
# so it must be a shell-component. --profile=lxqt picks up the aptosid wallpaper
# from /etc/xdg/pcmanfm-qt/lxqt/settings.conf (the profile the X11 LXQt session
# uses); the default profile sets no wallpaper, leaving a blank desktop.
shell-component=pcmanfm-qt --desktop --profile=lxqt
shell-component=lxqt-notificationd
shell-component=lxqt-policykit-agent
# lxqt-panel must be a shell-component: miriway restricts the wlr foreign-
# toplevel protocol (the taskbar's backend) to shell components.
shell-component=lxqt-panel

shell-alt=Space:lxqt-runner
shell-alt=F2:lxqt-runner
shell-meta=l:lxqt-leave --lockscreen

meta=p:pcmanfm-qt
meta=Return:qterminal
meta=t:qterminal
meta=grave:qterminal
ctrl-alt=t:qterminal

meta=Left:@dock-left
meta=Right:@dock-right
meta=Space:@toggle-maximized
meta=Home:@workspace-begin
meta=End:@workspace-end
meta=Page_Up:@workspace-up
meta=Page_Down:@workspace-down
ctrl-alt=Up:@toggle-always-on-top
ctrl-alt=BackSpace:@exit
