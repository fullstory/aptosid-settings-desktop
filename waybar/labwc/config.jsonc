// -*- mode: jsonc -*-
{
    "layer": "top",
    "position": "top",
    "height": 32,
    "spacing": 6,
    "margin-left": 6,
    "margin-right": 6,
    "modules-left": [
        "custom/appmenu",
        "wlr/taskbar"
    ],
    "modules-center": [
        "mpris"
    ],
    "modules-right": [
        "battery",
        "idle_inhibitor",
        "power-profiles-daemon",
        "backlight",
        "network",
        "wireplumber",
        "tray",
        "user",
        "clock"
    ],
    "custom/appmenu": {
        "format": "’Ćē",
        "tooltip": false,
        "on-click": "/usr/libexec/aptosid-wofi labwc --show drun"
    },
    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 14,
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close",
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "’ü«",
            "deactivated": "’ü░"
        }
    },
    "tray": {
        // "icon-size": 21,
        "spacing": 10
    },
    "backlight": {
        "format": "{percent}% {icon}",
        "format-icons": ["’åģ"],
        "scroll-step": 5,
        "tooltip-format": "Backlight: {percent}%"
    },
    "mpris": {
        "format": "{status_icon} {dynamic}",
        "status-icons": { "playing": "’üŗ", "paused": "’üī" },
        "dynamic-order": ["title", "artist"],
        "dynamic-len": 30,
        "tooltip-format": "{title}\n{artist}\n{album}"
    },
    "user": {
        "format": "{user}",
        "icon": true,
        "open-on-click": true
    },
    "clock": {
        // "timezone": "America/New_York",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d}"
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-full": "{capacity}% {icon}",
        "format-charging": "{capacity}% ’Ś¦",
        "format-plugged": "{capacity}% ’ć”",
        "format-alt": "{time} {icon}",
        "format-icons": ["’ēä", "’ēā", "’ēé", "’ēü", "’ēĆ"]
    },
    "power-profiles-daemon": {
        "format": "{icon}",
        "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
        "tooltip": true,
        "format-icons": {
            "default": "’ā¦",
            "performance": "’ā¦",
            "balanced": "’ēÄ",
            "power-saver": "’ü¼"
        }
    },
    "network": {
        "format-wifi": "{signalStrength}% ’ć½",
        "format-ethernet": "’ø┐",
        "format-linked": "’ø┐",
        "format-disconnected": "’ü▒",
        "tooltip-format-wifi": "{essid}  ({signalStrength}%)\n{ipaddr}/{cidr}\nvia {gwaddr}",
        "tooltip-format-ethernet": "{ifname}\n{ipaddr}/{cidr}\nvia {gwaddr}",
        "tooltip-format-disconnected": "Disconnected",
        "on-click": "nm-connection-editor"
    },
    "wireplumber": {
        "format": "{volume}% {icon}",
        "format-muted": "’Ć”",
        "on-click": "pavucontrol-qt",
        "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "format-icons": ["’Ć”", "’Ć¦", "’Ć©"]
    },
}
