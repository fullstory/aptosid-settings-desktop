#!/bin/sh
# Launches Kodi for the kodi-flatpak.desktop session entry.
# Overrides: /etc/default/kodi-session-aptosid
#
# Shipped by kodi-session-aptosid.

set -eu

DEFAULTS=/etc/default/kodi-session-aptosid
[ -s "$DEFAULTS" ] && . "$DEFAULTS"

exec ${KODI_GBM_EXEC:-flatpak run tv.kodi.Kodi --standalone --windowing=gbm}
