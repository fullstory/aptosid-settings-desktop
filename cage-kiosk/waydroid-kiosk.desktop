[Desktop Entry]
Name=Waydroid Kiosk
Comment=Full-screen Waydroid (Android) appliance in the cage kiosk compositor
Exec=cage -s -- /usr/libexec/cage-kiosk waydroid show-full-ui
DesktopNames=waydroid-kiosk;wlroots
Type=Application
# consumed by "uwsm start ...", not a standalone session; -uwsm is the real one
NoDisplay=true
